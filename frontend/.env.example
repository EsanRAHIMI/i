# Development
NODE_ENV=development
PORT=3000

# Frontend Service Environment Configuration

# Next.js Configuration
# API URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8001

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/voice/stream/{session_id}

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Google OAuth (Public)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Application Settings
NEXT_PUBLIC_APP_NAME="Ai Department"
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENVIRONMENT=development

# Feature Flags
NEXT_PUBLIC_ENABLE_VOICE_INTERFACE=true
NEXT_PUBLIC_ENABLE_DIGITAL_AVATAR=true
NEXT_PUBLIC_ENABLE_FEDERATED_LEARNING=true

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Auth Settings
AUTH_DISABLE_PASSWORD_COMPLEXITY=1