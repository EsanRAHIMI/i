    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "framer-motion": "^12.37.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
