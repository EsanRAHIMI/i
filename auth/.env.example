# Auth Service Environment Variables

# Application
APP_NAME="I App Auth Service"
DEBUG=false
LOG_LEVEL=INFO

# Security
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT Keys (RS256) - Set these in production
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
JWT_PRIVATE_KEY_FILE="private.pem"
JWT_PUBLIC_KEY_FILE="public.pem"
JWT_KEYS_DIR="keys"
JWT_KEYS_REQUIRED=false

# Public Base URL (for avatar URLs)
AUTH_PUBLIC_BASE_URL=https://auth.aidepartment.net

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=i_assistant_auth
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Or use full DATABASE_URL
# DATABASE_URL=postgresql://user:password@host:port/database

# Redis (optional, for token blacklisting)
REDIS_URL=redis://localhost:6379/0

# CORS Origins
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:8001", "https://aidepartment.net", "https://auth.aidepartment.net"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@aidepartment.net
SMTP_USE_TLS=true
FRONTEND_URL=http://localhost:3000

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Monitoring
ENABLE_METRICS=true
SENTRY_DSN=""


AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-central-1
BUCKET_NAME=iapp-auth-uploads
S3_PREFIX=avatars
CLOUDFRONT_BASE_URL=https://dvunuoe8609h3.cloudfront.net