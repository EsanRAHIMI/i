# Auth Service Environment Variables

# Application
APP_NAME="I App Auth Service"
DEBUG=false
LOG_LEVEL=INFO

# Security
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_DISABLE_PASSWORD_COMPLEXITY=1

# JWT Keys (RS256) - Set these in production
JWT_PRIVATE_KEY="your_private_key_here"
JWT_PUBLIC_KEY="your_public_key_here"
JWT_PRIVATE_KEY_FILE="jwt_private_key.pem"
JWT_PUBLIC_KEY_FILE="jwt_public_key.pem"
JWT_KEYS_DIR="keys"
JWT_KEYS_REQUIRED=false

# Public Base URL (for avatar URLs)
AUTH_PUBLIC_BASE_URL=https://auth.aidepartment.net

# Database
POSTGRES_DB=i_DB
POSTGRES_USER=esan
POSTGRES_PASSWORD=Admin_1234_1234
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (optional, for token blacklisting)
REDIS_URL=redis://localhost:6379/0

# CORS Origins
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:8001", "https://aidepartment.net", "https://auth.aidepartment.net"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
FRONTEND_URL=http://localhost:3000

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Monitoring
ENABLE_METRICS=true
SENTRY_DSN=""

# S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=me-central-1
BUCKET_NAME=iapp-auth-uploads
S3_PREFIX=avatars
CLOUDFRONT_BASE_URL=https://your-distribution.cloudfront.net