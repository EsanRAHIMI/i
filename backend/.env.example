# Backend Service Environment Configuration
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8001

# Database
DATABASE_URL=postgresql://esan:your_password_here@localhost:5432/i_DB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=i_DB
POSTGRES_USER=esan
POSTGRES_PASSWORD=your_password_here

# Redis
REDIS_DISABLE_AUTH=true
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/calendar/oauth/callback

# Webhook Configuration
CALENDAR_WEBHOOK_URL=https://your-domain.net/api/v1/calendar/webhook

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret

# AI Services
OPENAI_API_KEY=your_openai_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
WHISPER_MODEL_SIZE=base

# Security
ENCRYPTION_KEY=your_32_character_encryption_key
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Application
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# Email (for notification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30