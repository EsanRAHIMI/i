# =============================================================================
# 🌎 i-Assistant Master Environment File (Template & Reference)
# =============================================================================
# This file serves as a template master record for all environment variables 
# used across all services, and also provide values for docker-compose.yml.
# Copy this to .env and fill in the values.

# -----------------------------------------------------------------------------
# 📦 Docker Infrastructure (Used by docker-compose.yml)
# -----------------------------------------------------------------------------
POSTGRES_DB=i_DB
POSTGRES_USER=esan
POSTGRES_PASSWORD=Admin_1234_1234
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

MINIO_ROOT_USER=esan
MINIO_ROOT_PASSWORD=Admin_1234_1234
MINIO_ENDPOINT=localhost:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# 🔐 Shared Security & Identity
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=your_32_character_encryption_key
AUTH_DISABLE_PASSWORD_COMPLEXITY=1

# -----------------------------------------------------------------------------
# 📡 Service Connection URLs
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
BACKEND_API_URL=http://localhost:8000/api/v1
AUTH_API_URL=http://localhost:8001
WS_URL=ws://localhost:8000/api/v1/voice/stream/{session_id}

# -----------------------------------------------------------------------------
# 🤖 AI & External APIs
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
WHISPER_MODEL_SIZE=base

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/calendar/oauth/callback

WHATSAPP_ACCESS_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_id
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret

# -----------------------------------------------------------------------------
# 📧 SMTP (Email)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# -----------------------------------------------------------------------------
# ☁️ S3 / Storage (Auth Service)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=me-central-1
BUCKET_NAME=iapp-auth-uploads
S3_PREFIX=avatars
CLOUDFRONT_BASE_URL=https://your-distribution.cloudfront.net

# -----------------------------------------------------------------------------
# 📊 Monitoring & App Config
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_APP_NAME="i Agent"
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENABLE_VOICE_INTERFACE=true
NEXT_PUBLIC_ENABLE_DIGITAL_AVATAR=true
NEXT_PUBLIC_ENABLE_FEDERATED_LEARNING=true

# -----------------------------------------------------------------------------
# 🔑 Specific Service Vars (If any remaining)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=your_nextauth_secret
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:8000"]